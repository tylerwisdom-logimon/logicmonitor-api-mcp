      {
        "userPrompt": "Get the full details for SDT R_42.",
        "expected": [
          {
            "toolName": "lm_sdt",
            "arguments": {
              "operation": "get",
              "id": "R_42"
            }
          }
        ]
      }
    ]
  },
  {
