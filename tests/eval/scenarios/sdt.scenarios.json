[
  {
    "id": "sdt-list-active",
    "description": "List all currently active SDTs should use lm_sdt with isEffective filter",
    "category": "tool-selection",
    "tags": ["sdt", "list", "filter"],
    "steps": [
      {
        "userPrompt": "Show me all currently active scheduled downtimes in our environment.",
        "expected": [
          {
            "toolName": "lm_sdt",
            "arguments": {
              "operation": "list",
              "filter": { "contains": "isEffective" }
            }
          }
        ]
      }
    ]
  },
  {
    "id": "sdt-create-device",
    "description": "Create a one-time SDT on a device should use lm_sdt create with ResourceSDT type",
    "category": "parameter-mapping",
    "tags": ["sdt", "create", "device"],
    "steps": [
      {
        "userPrompt": "Put device 42 into a one-time maintenance window starting now for 2 hours. Add a comment saying 'Patching server'.",
        "expected": [
          {
            "toolName": "lm_sdt",
            "arguments": {
              "operation": "create",
              "type": { "contains": "ResourceSDT" },
              "deviceId": 42,
              "comment": { "contains": "Patching" }
            }
          }
        ]
      }
    ]
  },
  {
