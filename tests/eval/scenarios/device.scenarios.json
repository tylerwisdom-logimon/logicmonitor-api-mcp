  {
    "id": "device-create-single",
    "description": "Create a single device with all required fields using correct parameter names",
    "category": "parameter-extraction",
    "tags": ["device", "create"],
    "steps": [
      {
        "userPrompt": "Add a new server to monitoring. The display name should be 'web-prod-03', the hostname is 10.0.1.55, put it in group 12, and use collector 7.",
        "expected": [
          {
            "toolName": "lm_device",
            "arguments": {
              "operation": "create",
              "displayName": { "exact": "web-prod-03" },
              "name": { "exact": "10.0.1.55" },
              "hostGroupIds": { "exact": [12] },
              "preferredCollectorId": { "exact": 7 }
            }
          }
        ]
      }
    ]
  },
  {
    "id": "device-create-correct-field-names",
    "description": "Verify the LLM uses the correct field names (displayName not display_name, hostGroupIds not groupIds, etc.)",
    "category": "edge-case",
    "tags": ["device", "create", "field-names"],
    "steps": [
      {
        "userPrompt": "Create a device called 'db-replica-east' at address db-east.internal.corp, assign it to groups 5 and 8, monitored by collector 14, and turn off alerting for now.",
        "expected": [
          {
            "toolName": "lm_device",
            "arguments": {
              "operation": "create",
              "displayName": { "exact": "db-replica-east" },
              "name": { "exact": "db-east.internal.corp" },
              "hostGroupIds": { "exact": [5, 8] },
              "preferredCollectorId": { "exact": 14 },
              "disableAlerting": { "exact": true }
            }
          }
        ]
      }
    ]
  },
