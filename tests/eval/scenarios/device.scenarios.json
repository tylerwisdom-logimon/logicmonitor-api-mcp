[
  {
    "id": "device-list-basic",
    "description": "List all devices with no filters",
    "category": "operation-selection",
    "tags": ["device", "list"],
    "steps": [
      {
        "userPrompt": "Show me all the devices in our LogicMonitor account.",
        "expected": [
          {
            "toolName": "lm_device",
            "arguments": {
              "operation": "list",
              "filter": { "absent": true }
            }
          }
        ]
      }
    ]
  },
  {
