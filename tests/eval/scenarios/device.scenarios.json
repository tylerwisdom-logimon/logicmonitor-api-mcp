  {
    "id": "device-batch-update-apply-to-previous",
    "description": "Batch update using applyToPrevious to target devices from a prior list result",
    "category": "multi-step",
    "tags": ["device", "update", "batch", "session"],
    "steps": [
      {
        "userPrompt": "List all the devices in the staging environment.",
        "expected": [
          {
            "toolName": "lm_device",
            "arguments": {
              "operation": "list",
              "filter": { "present": true }
            }
          }
        ],
        "syntheticResult": "Found 9 devices matching filter. Results stored in session variable 'lastDeviceListIds'."
      },
      {
        "userPrompt": "Great, now disable alerting on all of those devices you just found.",
        "expected": [
          {
            "toolName": "lm_device",
            "arguments": {
              "operation": "update",
              "applyToPrevious": { "contains": "lastDeviceListIds" },
              "disableAlerting": { "exact": true }
            }
          }
        ]
      }
    ]
  }
]
